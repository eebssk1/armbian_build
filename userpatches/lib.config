# 1. More robust renaming logic
if declare -f dpkg_deb_build >/dev/null; then
  # We rename the function but preserve the rest of the line's structure
  eval "$(declare -f dpkg_deb_build | sed "1s/dpkg_deb_build/original_dpkg_deb_build/")"
else
  display_alert "Warning" "dpkg_deb_build not found; check your Armbian version" "wrn"
fi

dpkg_deb_build() {
  local staging_dir="${1:-}"
  
  # Fail-safe: if staging_dir is missing, just let the original function error out
  [[ -z "$staging_dir" ]] && { original_dpkg_deb_build "$@"; return; }

  # TARGETING: Only modify armbian-firmware variants
  if [[ "${artifact_name}" == "armbian-firmware"* ]]; then
    display_alert "Surgical Patch" "Injecting 30dBm regulatory fix into ${artifact_name}" "info"

    # Precedence: /lib/firmware/updates overrides everything else
    local target_path="${staging_dir}/lib/firmware/updates"
    mkdir -p "${target_path}"

    # 1. OVERRIDE REGULATORY DB
    if [[ -f "${SRC}/userpatches/regulatory.db" ]]; then
      cp "${SRC}/userpatches/regulatory.db" "${target_path}/"
      [[ -f "${SRC}/userpatches/regulatory.db.p7s" ]] && cp "${SRC}/userpatches/regulatory.db.p7s" "${target_path}/"
    else
      display_alert "Error" "Custom regulatory.db missing in userpatches/" "err"
    fi

    if [[ -f "${SRC}/userpatches/brcmfmac43456-sdio.bin" ]]; then
      cp "${SRC}/userpatches/brcmfmac43456-sdio.bin" "${target_path}/../brcm/"
      [[ -f "${SRC}/userpatches/brcmfmac43456-sdio.clm_blob" ]] && cp "${SRC}/userpatches/brcmfmac43456-sdio.clm_blob" "${target_path}/../brcm/"
    else
      display_alert "Error" "Brcm firmware update missing in userpatches/" "err"
    fi

    # 2. OVERRIDE BDF (The 'Stuck 20/33' Killer)
    # Since you have the WCN6855 (ath11k), this is usually the real culprit
    local bdf_path="${staging_dir}/lib/firmware/updates/ath11k/WCN6855/hw2.0"
    if [[ -d "${bdf_path}" && -f "${SRC}/userpatches/board-2.bin" ]]; then
      display_alert "Surgical Patch" "Bypassing hardware lock via custom BDF" "info"
      cp "${SRC}/userpatches/board-2.bin" "${bdf_path}/board-2.bin"
    fi
  fi

  # Call the original function to handle md5sums and final .deb packaging
  original_dpkg_deb_build "$@"
}
