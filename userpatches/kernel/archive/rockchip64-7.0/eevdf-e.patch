@@ -81,6 +81,10 @@ static unsigned int normalized_sysctl_sched_base_slice	= 700000ULL;
 
 __read_mostly unsigned int sysctl_sched_migration_cost	= 500000UL;
 
+__read_mostly unsigned int sysctl_sched_burst_penalty_enable = 1;
+__read_mostly unsigned int sysctl_sched_burst_penalty_nice_strict = 1;
+__read_mostly unsigned int sysctl_sched_burst_penalty_relief = 4;
+
 static int __init setup_sched_thermal_decay_shift(char *str)
 {
 	pr_warn("Ignoring the deprecated sched_thermal_decay_shift= option\n");
@@ -5279,6 +5283,40 @@ place_entity(struct cfs_rq *cfs_rq, struct sched_entity *se, int flags)
 		lag = div_s64(lag, load);
 	}
 
+	#define WAKEUP_PENALTY_THRESHOLD 711
+	#define UTIL_LOW_THRESHOLD       76
+
+	if (unlikely(sysctl_sched_burst_penalty_enable &&
+	    se->avg.wakeup_avg > WAKEUP_PENALTY_THRESHOLD &&
+	    se->avg.util_avg < UTIL_LOW_THRESHOLD)) {
+		bool do_punish = true;
+		if (entity_is_task(se)) {
+			struct task_struct *p = task_of(se);
+			if (unlikely(sysctl_sched_burst_penalty_nice_strict && task_nice(p) < 0))
+				do_punish = false;
+		} else {
+			do_punish = false;
+		}
+		if (do_punish) {
+			se->wakeup_penalty_count++;
+			if (unlikely(sysctl_sched_burst_penalty_relief > 0 &&
+			    se->wakeup_penalty_count >= sysctl_sched_burst_penalty_relief)) {
+				se->wakeup_penalty_count = 0;
+				if (lag > 0)
+					lag += lag / 10;
+				if (se->vlag > 0)
+					se->vlag += se->vlag / 10;
+			} else {
+				if (lag > 0)
+					lag -= lag / 3;
+				if (se->vlag > 0)
+					se->vlag -= se->vlag / 3;
+			}
+		}
+	} else {
+		se->wakeup_penalty_count = 0;
+	}
+
 	se->vruntime = vruntime - lag;
 
 	if (se->rel_deadline) {
