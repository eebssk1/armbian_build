 {
 	bool curr = cfs_rq->curr == se;
 
+	if (flags & ENQUEUE_WAKEUP) {
+		se->avg.wakeup_sum += 1008;
+	}
+
 	/*
 	 * If we're the current task, we must renormalise before calling
 	 * update_curr().
